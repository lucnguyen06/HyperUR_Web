# HyperUR Hub - Environment Configuration
# Copy file này thành .env và điền thông tin của bạn

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hyperur_db
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=HyperUR Hub
APP_URL=http://localhost
APP_DEBUG=true

# Security
SESSION_LIFETIME=7
TOKEN_EXPIRY_DAYS=30
BCRYPT_COST=12
